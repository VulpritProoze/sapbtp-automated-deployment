{
  "name": "iflow-cli",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "pull": "ts-node src/cli.ts pull",
    "push": "ts-node src/cli.ts push",
    "deploy": "ts-node src/cli.ts deploy",
    "diff": "ts-node src/cli.ts diff",
    "status": "ts-node src/cli.ts status",
    "init": "ts-node src/cli.ts init",
    "build": "tsc --outDir dist --rootDir src",
    "prepack": "npm run build",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci": "npm run typecheck && npm run lint && npm run test:coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "adm-zip": "^0.5.17",
    "axios": "^1.16.1",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25.7.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^8.57.1",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "bin": {
    "iflow-cli": "dist/cli.js"
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    "import": "./dist/index.js",
    "require": "./dist/index.js"
  }
}
